# ── Telegram ──
# Get api_id and api_hash from https://my.telegram.org
TG_API_ID=12345678
TG_API_HASH=abcdef0123456789abcdef0123456789

# Session string — generate with: python generate_session.py
TG_SESSION=1BVtsOKwBu...long-string...==

# Source group chat IDs — comma-separated (negative numbers for groups)
# Find by running: python list_groups.py
TG_CHAT_IDS=-1001234567890,-1009876543210

# ── Discord Webhooks ──
# #signals channel — raw Telegram relay (existing)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# #executions channel — trade confirmations, fills, P&L (optional)
DISCORD_WEBHOOK_EXECUTIONS=https://discord.com/api/webhooks/...

# #alerts channel — errors, warnings, connection issues (optional)
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/...

# ── General ──
TIMEZONE=Europe/Berlin

# ── Trading ──
# Master switch: set to true to enable trade execution
TRADING_ENABLED=false

# Dry-run mode: parses and calculates but does NOT execute trades
# Set to false only when you're ready to go live
TRADING_DRY_RUN=true

# MT5 backend: "dry_run", "rest_api"
MT5_BACKEND=rest_api

# MT5 connection (REST API bridge host/port)
MT5_HOST=localhost
MT5_PORT=18812

# MT5 magic number for order identification (default: 202603)
MT5_MAGIC_NUMBER=202603

# MT5 REST API authentication (for rest_api backend)
MT5_API_KEY=your_api_key_here
MT5_USE_TLS=true

# Path to accounts configuration file
ACCOUNTS_CONFIG=accounts.json

# PostgreSQL connection (shared VPS instance)
# Format: postgresql://user:password@host:port/dbname
# Special chars in password must be URL-encoded
DATABASE_URL=postgresql://telebot:your_password@localhost:5432/telebot

# ── Dashboard ──
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080

# Host-side port for the dev compose stack. Defaults to 8090 because 8080 often
# collides with devdock-caddy. Override in .env.dev if 8090 is also in use.
# DASHBOARD_HOST_PORT=8090

# ── Dashboard auth (Phase 5 — argon2 + SessionMiddleware) ──
# ⚠ IMPORTANT when using docker-compose env_file:
# argon2 hashes contain `$` characters (e.g. $argon2id$v=19$m=...). Docker-compose
# performs variable interpolation on values in env_file entries and will EAT most
# of the hash, producing a cryptic "DASHBOARD_PASS_HASH missing or malformed" FATAL
# at startup. Two fixes, pick one:
#   (a) Double every `$` in the hash: $$argon2id$$v=19$$m=... (let docker-compose
#       collapse each $$ back to a single $).
#   (b) Move the variable into the compose file's `environment:` block with single
#       quotes: DASHBOARD_PASS_HASH='$argon2id$v=19$m=...' (no interpolation).
# Reference: UAT 05 Test 1 pre-flight fix.
#
# ⚠ IMPORTANT when using .env.dev for the dev compose stack:
# .env.dev needs the same Phase 5 migration this file documents. REMOVE legacy
# DASHBOARD_USER / DASHBOARD_PASS lines and ADD DASHBOARD_PASS_HASH,
# SESSION_SECRET, SESSION_COOKIE_SECURE (use `SESSION_COOKIE_SECURE=false` for
# local HTTP dev). The bot will SystemExit on boot otherwise — see
# config.py::_require_dashboard_hash and _require_session_secret.
#
# Generate hash with: python scripts/hash_password.py
# ⚠ When pasting the real hash on the line below, either double every `$` (fix (a) above)
# or move the variable to compose's `environment:` block with single quotes (fix (b)).
DASHBOARD_PASS_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# Session signing key. MUST be ≥32 bytes of entropy.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change_me_openssl_rand_base64_48

# Set to false only for local HTTP dev / pytest. Prod MUST be true.
SESSION_COOKIE_SECURE=true

# ── MT5 Account Passwords ──
# Referenced by password_env in accounts.json
# MT5_PASS_1=your_mt5_password_here
# MT5_PASS_2=your_mt5_password_here
# MT5_PASS_3=your_mt5_password_here
